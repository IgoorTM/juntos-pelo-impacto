# Variáveis consumidas pelo backend quando rodado LOCALMENTE (fora do
# container). Em Docker, as variáveis são injetadas pelo docker-compose
# a partir do .env da raiz do repositório.

# Conexão com o Postgres do docker-compose (via porta publicada no host).
DATABASE_URL=postgresql://juntos:juntos@localhost:5432/juntos_dev

# Segredo do JWT — trocar em produção.
JWT_SECRET=dev-secret

# Porta do servidor HTTP.
PORT=3000
