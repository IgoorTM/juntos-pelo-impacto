{
  "name": "juntos-pelo-impacto",
  "version": "0.0.1",
  "private": true,
  "description": "Sistema de Gestão Juntos pelo Impacto — MVP",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:frontend": "npm run dev --workspace @juntos/frontend",
    "dev:backend": "npm run start:dev --workspace @juntos/backend --if-present",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "clean": "npm exec --workspaces -- rm -rf dist build .next"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
