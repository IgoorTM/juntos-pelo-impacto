{
  "name": "juntos-pelo-impacto",
  "version": "0.0.1",
  "private": true,
  "description": "Sistema de Gestão Juntos pelo Impacto — MVP",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:frontend": "npm run dev --workspace @juntos/frontend",
    "dev:backend": "npm run start:dev --workspace @juntos/backend --if-present",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "clean": "npm exec --workspaces -- rm -rf dist build .next",
    "docker:db": "docker compose up -d postgres",
    "docker:db:down": "docker compose stop postgres",
    "docker:dev": "docker compose -f docker-compose.yml -f docker-compose.dev.yml --profile full up",
    "docker:dev:build": "docker compose -f docker-compose.yml -f docker-compose.dev.yml --profile full up --build",
    "docker:prod": "docker compose --profile full up -d",
    "docker:prod:build": "docker compose --profile full up -d --build",
    "docker:down": "docker compose --profile full down",
    "docker:down:volumes": "docker compose --profile full down -v",
    "docker:logs": "docker compose --profile full logs -f"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
