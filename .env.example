# Variáveis consumidas pelo docker-compose.yml (raiz do monorepo).
# Copie para .env e ajuste os valores conforme o ambiente.
# O .env real NÃO deve ser commitado.

# ─── Host user (evita arquivos gerados pelo container com owner root) ──────
# Execute: id -u  para obter o UID e  id -g  para o GID do seu usuário
UID=1000
GID=1000

# ─── Postgres ──────────────────────────────────────────────────────────────
POSTGRES_USER=juntos
POSTGRES_PASSWORD=juntos
POSTGRES_DB=juntos_dev
POSTGRES_PORT=5432

# ─── Backend ───────────────────────────────────────────────────────────────
BACKEND_PORT=3000
JWT_SECRET=change-me-in-production

# ─── Frontend ──────────────────────────────────────────────────────────────
FRONTEND_PORT=5173
VITE_API_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:5173
