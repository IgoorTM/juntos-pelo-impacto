# Variáveis consumidas pelo docker-compose.yml (raiz do monorepo).
# Copie para .env e ajuste os valores conforme o ambiente.
# O .env real NÃO deve ser commitado.

# ─── Postgres ──────────────────────────────────────────────────────────────
POSTGRES_USER=juntos
POSTGRES_PASSWORD=juntos
POSTGRES_DB=juntos_dev
POSTGRES_PORT=5432

# ─── Backend ───────────────────────────────────────────────────────────────
BACKEND_PORT=3000
JWT_SECRET=change-me-in-production

# ─── Frontend ──────────────────────────────────────────────────────────────
FRONTEND_PORT=5173
VITE_API_URL=http://localhost:3000
